## 7. Monitoring & Observabilité

### Métriques Micrometer

```java
@Component
@RequiredArgsConstructor
public class SagaMetrics {

    private final MeterRegistry registry;
    
    // Counters
    private Counter membersProcessed;
    private Counter membersErrored;
    private Counter blocksCreated;
    private Counter sfSyncSuccess;
    private Counter sfSyncFailed;
    
    // Timers
    private Timer memberProcessingTimer;
    private Timer sfSyncTimer;
    
    // Gauges - registered dynamically
    
    @PostConstruct
    void init() {
        membersProcessed = Counter.builder("saga.members.processed")
            .description("Total members processed successfully")
            .register(registry);
            
        membersErrored = Counter.builder("saga.members.errored")
            .description("Total members that failed processing")
            .register(registry);
            
        blocksCreated = Counter.builder("saga.blocks.created")
            .description("Total blocks created")
            .register(registry);
            
        memberProcessingTimer = Timer.builder("saga.member.processing.duration")
            .description("Time to process a single member")
            .publishPercentiles(0.5, 0.95, 0.99)
            .register(registry);
            
        // Gauge for active sagas
        Gauge.builder("saga.active.count", sagaRepo, 
            repo -> repo.countByStepNotIn(List.of(SagaStep.COMPLETED, SagaStep.FAILED)))
            .register(registry);
    }
    
    public Timer.Sample startMemberProcessing() {
        return Timer.start(registry);
    }
    
    public void recordMemberSuccess(Timer.Sample sample) {
        sample.stop(memberProcessingTimer);
        membersProcessed.increment();
    }
    
    public void recordMemberError(Timer.Sample sample) {
        sample.stop(memberProcessingTimer);
        membersErrored.increment();
    }
}
```

