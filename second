Container(blocks, "Block Manager", "Spring", "Type-2 history, approved-gate, review attach")
Container(outbox, "Salesforce Outbox", "Spring", "Local queue, retry, dedup")
ContainerDb(db, "GO DB", "HIT\_INBOX, REVIEW\_INSTANCE, REVIEW\_WORK, PARTY, BLOCK, BLOCK\_VERSION, REVIEW\_TARGET, ROLE\_BLOCK\_POLICY, OUTBOX")
}
