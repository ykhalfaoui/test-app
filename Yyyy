    state "Sequential Sync Loop (Re-entrant)" as Sync {
        SYNC_READY --> SYNCING_MEMBERS
        SYNCING_MEMBERS --> SYNCING_BLOCKS : Members Cursor >= Total
        SYNCING_BLOCKS --> COMPLETED : Blocks Cursor >= Total
        
        SYNCING_MEMBERS --> SYNCING_MEMBERS : Batch Ack (Offset + 200)
        SYNCING_BLOCKS --> SYNCING_BLOCKS : Batch Ack (Offset + 200)
    }

    COMPLETED --> [*]
    
    note right of Gen : Handled by Async Workers\n(Java 17 Thread Pool)
    note right of Sync : Handled by Event Loop\n(No Long Transactions)
